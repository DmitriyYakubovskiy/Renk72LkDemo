@model CreateBidViewModel
@{
    var isDisabled = Model.Bid.Step5.OtherFile?.FilePath != null;
}

<div class="lk-block-info lk-block-info--mod">
    <div class="lk-block-info__container">
        <div class="form-group">
            Прочие документы (Размер файла не более 10 Мб)
        </div>

        <div class="form-group" name="container-@nameof(Model.Bid.Step5.OtherFiles)">
            <input type="file" class="form-group__filSe" id="filename_5" accept=".jpg, .jpeg, .png, .pdf" name="@nameof(Model.Bid.Step5.OtherFiles)"
                   asp-for="@Model.Bid.Step5.OtherFiles" disabled="@isDisabled" multiple />
        </div>

        @if (Model.Bid.Step5.OtherFile?.FilePath != null)
        {
            <div class="uploaded-file-info" style="background: #f5f5f5; border-radius: 4px;">
                <div style="display: flex; align-items: center; gap: 10px;">
                    <span style="color: green;">✔ Документ загружен:</span>
                    <a href="@Model.Bid.Step5.OtherFile.FilePath" target="_blank"  style="color: #0066cc; text-decoration: underline;">
                        @Model.Bid.Step5.OtherFile.FileName
                    </a>
                    <button type="button" onclick="removeUploadedFile('otherFile')"  style="margin-left: auto; color: #ff0000; background: none; border: none; cursor: pointer;">
                        Удалить
                    </button>
                </div>
            </div>
        }
    </div>
</div>