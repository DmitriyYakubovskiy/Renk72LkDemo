@model (AddressesViewModel, bool)

<div class="bg-blue-900 text-white px-4 py-2 rounded-lg font-semibold mb-4">
    Адрес физического лица
</div>

<div class="space-y-6">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
        <div class="space-y-4">
            <div class="text-sm font-semibold text-gray-700">Регистрационный адрес</div>

            <div class="space-y-2">
                <label for="address_reg" class="text-sm font-medium text-gray-700">Адрес в свободной форме</label>
                <input
                    type="text"
                    placeholder="Введите адрес до дома"
                    onfocus="dadate(this.id)"
                    id="address_reg"
                    name="@($"{nameof(Model.Item1.RegistrationAddress)}.{nameof(Model.Item1.RegistrationAddress.FullAddress)}")"
                    value="@Model.Item1?.RegistrationAddress?.FullAddress"
                    dadate-input-manual
                    class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 text-sm"
                />
            </div>

            <div id="address_reg_full" dadate-input-container class="space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <input type="text" placeholder="Регион/район" dadate-input-manual
                           id="adrreg_obl"
                           name="@($"{nameof(Model.Item1.RegistrationAddress)}.{nameof(Model.Item1.RegistrationAddress.Region)}")"
                           value="@Model.Item1?.RegistrationAddress?.Region"
                           class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 text-sm"/>
                    <input type="text" placeholder="Населенный пункт" dadate-input-manual
                           id="adrreg_city"
                           name="@($"{nameof(Model.Item1.RegistrationAddress)}.{nameof(Model.Item1.RegistrationAddress.City)}")"
                           value="@Model.Item1?.RegistrationAddress?.City"
                           class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 text-sm"/>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <input type="text" placeholder="Улица" dadate-input-manual
                           id="adrreg_str"
                           name="@($"{nameof(Model.Item1.RegistrationAddress)}.{nameof(Model.Item1.RegistrationAddress.Street)}")"
                           value="@Model.Item1?.RegistrationAddress?.Street"
                           class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 text-sm"/>
                    <input type="text" placeholder="ИНДЕКС" dadate-input-manual
                           id="adrreg_index"
                           name="@($"{nameof(Model.Item1.RegistrationAddress)}.{nameof(Model.Item1.RegistrationAddress.Index)}")"
                           value="@Model.Item1?.RegistrationAddress?.Index"
                           class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 text-sm"/>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <input type="text" placeholder="Дом" dadate-input-manual
                           id="adrreg_house"
                           name="@($"{nameof(Model.Item1.RegistrationAddress)}.{nameof(Model.Item1.RegistrationAddress.House)}")"
                           value="@Model.Item1?.RegistrationAddress?.House"
                           class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 text-sm"/>
                    <input type="text" placeholder="Офис/кв" dadate-input-manual
                           id="adrreg_office"
                           name="@($"{nameof(Model.Item1.RegistrationAddress)}.{nameof(Model.Item1.RegistrationAddress.Office)}")"
                           value="@Model.Item1?.RegistrationAddress?.Office"
                           class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 text-sm"/>
                </div>
            </div>
        </div>

        <div class="space-y-4">
            <div class="text-sm font-semibold text-gray-700">Фактический адрес</div>

            <div class="space-y-2">
                <label for="address_actual" class="text-sm font-medium text-gray-700">Адрес в свободной форме</label>
                <input
                    type="text"
                    placeholder="Введите адрес до дома"
                    onfocus="dadate(this.id)"
                    id="address_actual"
                    name="@($"{nameof(Model.Item1.ActualAddress)}.{nameof(Model.Item1.ActualAddress.FullAddress)}")"
                    value="@Model.Item1?.ActualAddress?.FullAddress"
                    class="w-full bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 text-sm"/>
            </div>

            <div style="display:none" id="address_actual_full" class="space-y-4">
                <div class="grid grid-cols-2 gap-4">
                    <input type="text" placeholder="Регион/район"
                           id="adract_obl"
                           name="@($"{nameof(Model.Item1.ActualAddress)}.{nameof(Model.Item1.ActualAddress.Region)}")"
                           value="@Model.Item1?.ActualAddress?.Region"
                           class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 text-sm"/>
                    <input type="text" placeholder="Населенный пункт"
                           id="adract_city"
                           name="@($"{nameof(Model.Item1.ActualAddress)}.{nameof(Model.Item1.ActualAddress.City)}")"
                           value="@Model.Item1?.ActualAddress?.City"
                           class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 text-sm"/>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <input type="text" placeholder="Улица"
                           id="adract_str"
                           name="@($"{nameof(Model.Item1.ActualAddress)}.{nameof(Model.Item1.ActualAddress.Street)}")"
                           value="@Model.Item1?.ActualAddress?.Street"
                           class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 text-sm"/>
                    <input type="text" placeholder="ИНДЕКС"
                           id="adract_index"
                           name="@($"{nameof(Model.Item1.ActualAddress)}.{nameof(Model.Item1.ActualAddress.Index)}")"
                           value="@Model.Item1?.ActualAddress?.Index"
                           class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 text-sm"/>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <input type="text" placeholder="Дом"
                           id="adract_house"
                           name="@($"{nameof(Model.Item1.ActualAddress)}.{nameof(Model.Item1.ActualAddress.House)}")"
                           value="@Model.Item1?.ActualAddress?.House"
                           class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 text-sm"/>
                    <input type="text" placeholder="Офис/кв"
                           id="adract_office"
                           name="@($"{nameof(Model.Item1.ActualAddress)}.{nameof(Model.Item1.ActualAddress.Office)}")"
                           value="@Model.Item1?.ActualAddress?.Office"
                           class="bg-gray-50 border border-gray-200 rounded-lg px-4 py-2 text-sm"/>
                </div>
            </div>
        </div>

        <div class="col-span-full flex items-center space-x-2 mt-2">
            <input type="checkbox" id="copy_block" class="w-4 h-4 text-blue-600 border-gray-300 rounded" checked />
            <label for="copy_block" class="text-sm text-gray-700">Адреса совпадают</label>
        </div>
    </div>
</div>


<script>
    function copyaddress() {
        elem =  document.getElementById('copy_block');
        if(elem.checked){
            $('#adract_index' ).val($('#adrreg_index').val());
            $("#adract_obl").val($('#adrreg_obl').val());
            $('#adract_city').val($('#adrreg_city').val());
            $('#adract_str' ).val($('#adrreg_str').val());
            $('#adract_house').val($('#adrreg_house').val());
            $('#adract_office').val($('#adrreg_office').val());
            $('#address_actual').val($('#address_reg').val());
            // $('#address_actual').attr('disabled', '')
            ChooseInfo('address_actual_full', '0')

        } else {
            // $('#address_actual').removeAttr('disabled');
            ChooseInfo('address_actual_full', '1')
        }
    }

    function dadateManual(address,id) {
      address = address.split('_')[0];
      $('#'+id).val(join([
        $('#'+address+'_obl').val(),
        $('#'+address+'_city').val(),
        $('#'+address+'_str').val(),
        $('#'+address+'_house').val(),
        $('#'+address+'_office').val(),
        $('#'+address+'_index').val()
      ]));
    }

    $(document).on('change', '#copy_block', function() {copyaddress()} );
    $(document).on('change', '#address_reg', function() {copyaddress()})
    $(document).on('change ', '[dadate-input-manual]', function () {
      id = this.closest("[dadate-input-container]").id.split('_full')[0];
      dadateManual(this.id,id);
      copyaddress();
      });
</script>