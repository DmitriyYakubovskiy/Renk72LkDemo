@using Renk72Lk.DataAccess.Extensions
@inject IConfiguration Configuration
@{
    ViewBag.DadataToken = Configuration["DadataToken"];
    ViewData["Title"] = "Личный кабинет ООО «РЭНК»";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="format-detection" content="telephone=no" />

    @Html.AntiForgeryToken()

    <title>@ViewData["Title"]</title>
    @await Html.PartialAsync("_Favicons")
    <script src="~/js/jquery-3.7.0.min.js"></script>
    <link rel="stylesheet" href="~/css/newstyle.css?v=56" />
    <link rel="stylesheet" href="~/css/output.css?v=1.0.3" />
    <link href="~/css/suggestions.min.css?v=1.11.2" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    @* <link href="~/css/suggestions.min.css" rel="stylesheet" />
    <link rel="stylesheet" media="all" href="~/css/default.css?v=230532" />
    <link rel="stylesheet" media="all" href="~/css/lk.css?v=0706" />
    <link rel="stylesheet" media="all" href="~/css/modules/list_users.css" />
    <link rel="stylesheet" media="all" href="~/css/modules/lk-block-info.css?v=2301271" />
    <link rel="stylesheet" href="~/css/modules/authorizing.css" />
    <link rel="stylesheet" media="all" href="~/css/oformlenie_zayavki.css?v=2501" />
    <link rel="stylesheet" href="~/css/modules/chat.css?v=220805" /> *@
</head>
<body class="min-h-screen overflow-x-hidden bg-page-100">
    <header class="bg-white border-b border-gray-200 py-3">
        <div class="max-w-screen-xl mx-auto px-4 flex flex-col lg:flex-row justify-between items-center gap-4">

            <!-- Левая часть -->
            <a href="/" class="flex items-center gap-3 no-underline text-black whitespace-nowrap">
                <img src="@Url.Content("~/img/RENK_Sign_Gradient_40_Cut.png")" alt="Региональная энергетическая компания" class="h-10 w-auto" />
                <div class="flex flex-col leading-tight">
                    <span class="text-md font-bold">Региональная</span>
                    <span class="text-sm text-gray-600">энергетическая компания</span>
                </div>
            </a>

            <div class="hidden lg:flex items-center justify-end gap-8 text-sm text-black flex-wrap">
        
                <!-- Адрес -->
                <div class="flex flex-col items-start text-left">
                    <div class="flex items-center gap-2 font-semibold">
                        <i class="fas fa-map-marker-alt text-gray-600"></i>
                        г. Тюмень, ул. Осипенко 19
                    </div>
                    <div class="text-xs text-gray-500">
                        пн. - пт.: 8:30 - 17:30 (обед 12:30 - 13:30)
                    </div>
                </div>

                <!-- Телефон -->
                <div class="flex flex-col items-start text-left">
                    <div class="flex items-center gap-2 font-medium">
                        <i class="fas fa-phone text-gray-600"></i>
                        +7 (3452) 50-08-54
                    </div>
                    <div class="text-xs text-gray-500">телефон офиса</div>
                </div>

                <!-- Авторизация -->
                <div class="flex items-center gap-2 text-blue-600 font-medium">
                    @if (User.Identity!.IsAuthenticated!)
                    {
                        <i class="fas fa-user"></i>
                        <a href="@Url.Action("Index", "Home")" class="hover:underline">@User.Identity.Name</a>
                        <span class="text-gray-300">|</span>
                        <a href="@Url.Action("Logout", "Account")" class="hover:underline">Выход</a>
                    }
                    else
                    {
                        <a href="@Url.Action("Register", "Account")" class="hover:underline">Регистрация</a>
                        <span class="text-gray-300">|</span>
                        <a href="@Url.Action("Login", "Account")" class="hover:underline flex items-center gap-1">
                            <i class="fas fa-user"></i> Вход
                        </a>
                    }
                </div>
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="bg-white border-b border-gray-200 py-3">
        <div class="max-w-screen-xl mx-auto px-4 flex flex-col lg:flex-row justify-between items-center gap-4">
            <!-- Левая часть: логотип + название -->
            <div class="flex items-center gap-3 text-center sm:text-left">
                <img src="@Url.Content("~/img/RENK_Sign_Gradient_40_Cut.png")"
                    alt="Региональная Энергетическая Компания"
                    class="h-10 w-auto" />
                <span class="text-black font-medium text-sm">Региональная Энергетическая Компания</span>
            </div>

            <!-- Правая часть: адрес + статус -->
            <div class="flex flex-col sm:flex-row items-center gap-1 text-gray-700 text-sm text-center sm:text-right">

                <!-- Адрес -->
                <div class="flex items-center gap-2 font-medium">
                    <i class="fas fa-map-marker-alt text-gray-600"></i>
                    <span>г. Тюмень, ул. Осипенко 19</span>
                </div>

                <!-- Статус -->
                <div class="flex items-center gap-2 ">
                    <span class="w-3 h-3 rounded-full status-dot" title="Проверка статуса"></span>
                    <span class="status-label">Статус</span>
                </div>
            </div>
        </div>


        <!-- Скрипты -->
        <script src="~/js/jquery.suggestions.min.js"></script>
        <script src="@Url.Content("~/js/modules/masked.js")"></script>
        @* <script src="@Url.Content("~/js/modules/datepicker.js")"></script> *@
        <script src="@Url.Content("~/js/modules/select-block.js")"></script>
        <script src="@Url.Content("~/js/modules/policy.js?v=0002")"></script>
        <script src="@Url.Content("~/js/modules/sidebarStiky.js?v=0003")"></script>
        <script src="@Url.Content("~/js/modules/modal.js")"></script>
        <script src="@Url.Content("~/js/modules/form-step.js?v=220826")"></script>
        <script src="@Url.Content("~/js/script.js?v=23037")"></script>

        <script>
            window.tokendadata = "@ViewBag.DadataToken";

            document.addEventListener("DOMContentLoaded", function () {
                const statusDot = document.querySelector(".status-dot");
                const statusLabel = document.querySelector(".status-label");

                const now = new Date(
                    new Date().toLocaleString("en-US", { timeZone: "Asia/Yekaterinburg" })
                );

                const day = now.getDay(); // 0 = Sunday
                const hour = now.getHours();
                let isOpen = (day >= 1 && day <= 5 && hour >= 9 && hour < 18);

                if (statusDot && statusLabel) {
                    if (isOpen) {
                        statusDot.style.backgroundColor = "#23c16b"; // зелёный
                        statusLabel.textContent = "Открыто";
                        statusDot.title = "Офис открыт";
                    } else {
                        statusDot.style.backgroundColor = "#d33"; // красный
                        statusLabel.textContent = "Закрыто";
                        statusDot.title = "Офис закрыт";
                    }
                }
            });
        </script>
    </footer>
</body>
</html>

<script>
    function showMessage(message, type) {
        const bg = type === 'success' ? 'bg-green-600' : 'bg-red-600';

        const msg = $(`
            <div class="global-message fixed top-6 left-1/2 -translate-x-1/2 ${bg} text-white px-6 py-3 rounded shadow z-50 animate-fadeIn">
                <i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-triangle'} mr-2"></i>
                ${message}
            </div>
        `);

        $('body').append(msg);

        setTimeout(() => {
            msg.fadeOut(300, () => msg.remove());
        }, 2500);
    }
</script>