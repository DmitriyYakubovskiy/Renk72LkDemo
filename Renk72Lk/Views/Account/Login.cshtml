@model LoginModel
@{
    ViewData["Title"] = "Вход в личный кабинет";
}

<div class="flex items-center justify-center min-h-screen bg-page px-4">
    <div class="bg-white rounded-xl shadow-lg w-full max-w-md p-10 text-center">
        <h2 class="text-2xl font-bold mb-2">Вход в личный кабинет</h2>
        <p class="text-gray-600 mb-6">Введите ваши данные для входа в систему</p>

        <form id="form">
            <div class="flex items-center bg-gray-50 border border-gray-300 rounded-lg mb-4 px-3 focus-within:outline outline-blue-500">
                <i class="fas fa-envelope text-gray-500 text-sm mr-3"></i>
                <input type="text" name="@nameof(Model.Login)" class="w-full bg-transparent p-3 outline-none text-gray-800 text-sm" placeholder="Логин или почта" required />
            </div>

            <div class="flex items-center bg-gray-50 border border-gray-300 rounded-lg mb-4 px-3 relative focus-within:outline outline-blue-500">
                <i class="fas fa-lock text-gray-500 text-sm mr-3"></i>
                <input type="password" id="password" name="@nameof(Model.Password)" class="w-full bg-transparent p-3 outline-none text-gray-800 text-sm" placeholder="Пароль" required />
                <button type="button" class="toggle-password absolute right-3 text-gray-500" onclick="togglePasswordVisibility()">
                    <i class="fas fa-eye"></i>
                </button>
            </div>

            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-lg transition">
                Войти →
            </button>
        </form>

        <div class="mt-6 text-sm text-gray-700 space-y-2">
            <a href="@Url.Action("ForgotPassword", "Account")" class="text-blue-600 hover:underline block">
                Напомнить пароль и логин?
            </a>
            <p>
                <a href="@Url.Action("Register", "Account")" class="font-bold text-blue-600 hover:underline">Зарегистрируйтесь</a>,
                если Вы ранее не пользовались Личным кабинетом.
            </p>
            <a href="#" class="text-blue-600 hover:underline inline-flex items-center">
                Инструкция по работе с Личным кабинетом <span class="ml-1">ℹ️</span>
            </a>
        </div>
    </div>
</div>

<script>
    $('#form').on('submit', function (event) {
        event.preventDefault();
        var formData = $(this);

        // Очистка предыдущих ошибок
        $('.login-error-message').remove();
        $('.floating-error').remove();
        $('.input-error-border').removeClass('ring-2 ring-red-500');

        // Установка токена (если используется AntiForgeryToken)
        $.ajaxSetup({
            beforeSend: function (xhr) {
                var token = $('input[name="__RequestVerificationToken"]').val();
                if (token) {
                    xhr.setRequestHeader("RequestVerificationToken", token);
                }
            }
        });

        // Отправка AJAX-запроса
        $.ajax({
            url: "login",
            type: "POST",
            data: formData.serialize(),
            success: function (data) {
                showMessage("Успешный вход. Перенаправление...", "success");
                window.location = '/';
            },
            error: function (err) {
                if (err.responseJSON?.errors) {
                    const errors = err.responseJSON.errors;

                    if (errors.mainError) {
                        showMessage(errors.mainError[0], "error");
                    }

                    for (const field in errors) {
                        if (field === "mainError") continue;

                        const input = $(`[name="${field}"]`);
                        const wrapper = input.parent();

                        wrapper.css('position', 'relative');

                        const errorTooltip = $(`
                            <div class="floating-error absolute top-full left-0 mt-1 z-50 bg-red-600 text-white text-sm rounded px-3 py-2 shadow">
                                ${errors[field][0]}
                                <div class="arrow-down absolute -top-1 left-4 w-0 h-0 border-l-8 border-r-8 border-b-8 border-transparent border-b-red-600"></div>
                            </div>
                        `);

                        wrapper.append(errorTooltip);

                        // Подсветка рамки
                        wrapper.addClass('ring-2 ring-red-500');

                        // Удаление подсказки через 2 секунды
                        setTimeout(() => {
                            errorTooltip.fadeOut(300, function () {
                                $(this).remove();
                                wrapper.removeClass('ring-2 ring-red-500');
                            });
                        }, 2000);
                    }
                } else {
                    showMessage("Произошла ошибка на сервере. Повторите позже.", "error");
                }
            }
        });
    });

    function togglePasswordVisibility() {
        const passwordInput = document.getElementById("password");
        const toggleButton = document.querySelector(".toggle-password");
        const icon = toggleButton.querySelector("i");

        const isPassword = passwordInput.type === "password";
        passwordInput.type = isPassword ? "text" : "password";

        // Переключаем иконку
        icon.classList.toggle("fa-eye", !isPassword);
        icon.classList.toggle("fa-eye-slash", isPassword);
    }
</script>