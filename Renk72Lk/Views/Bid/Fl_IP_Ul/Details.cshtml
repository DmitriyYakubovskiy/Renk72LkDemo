@model (BidModel, UserModel)

<section class="section">
    <h1 class="section__title">Обращение №@Model.Item1?.Id</h1>
    <div class="section__row section__row--reverse">
        <div class="sidebar">
            <div class="sidebar__box">
                <div class="request">
                    <div class="request__wrap">
                        <div class="request__title"><span>№ @Model.Item1?.Id</span> @Model.Item1?.Name</div>
                        <div class="request__list">
                            <div class="request__info">
                                <span class="request__name">Организация:</span>
                                <span class="request__text">@Model.Item1?.Department</span>
                            </div>
                            <div class="request__info">
                                <span class="request__name">Услуга:</span>
                                <span class="request__text">@Model.Item1?.Service</span>
                            </div>
                            <div class="request__btn">
                                <a href="@Model.Item1?.DocumentFile?.FilePath" target="_blank" class="btn">Скачать заявление</a>
                            </div>
                        </div>
                    </div>
                </div>
                @await Html.PartialAsync("Items/Bid/Details/Files")
            </div>     
        </div>
        @await Html.PartialAsync("Items/Bid/Details/Chat")
    </div>
</section>