@model CreateBidViewModel

<form class="form-bid" role="form" enctype="multipart/form-data">
    @Html.AntiForgeryToken()
    <div class="steps_content active" data-step="1">
        <input type="hidden" name="@nameof(Model.Bid.Step1.Id)" value="@Model?.Bid?.Step1?.Id" />
        <input type="hidden" name="@nameof(Model.Bid.Step1.BidId)" value="@Model?.Bid?.Step1?.BidId" />
        <input type="hidden" name="@nameof(Model.Bid.Step1.UserId)" value="@Model?.Bid?.Step1?.UserId" />
        <input type="hidden" name="@nameof(Model.Bid.Step1.Role)" value="@Model?.Bid?.Step1?.Role"  />

        @await Html.PartialAsync("Items/Bid/1/ConsumerDetailsSNP")
        @await Html.PartialAsync("Items/Passport", ((IPassportData)Model?.Bid?.Step1!, true))
        @await Html.PartialAsync("Items/ContactInfo", (IContactData)Model?.Bid?.Step1!)
        @await Html.PartialAsync("Items/AddressMore", (new AddressesViewModel() { ActualAddress = Model.Bid.Step1.ActualAddress, RegistrationAddress = Model.Bid.Step1.RegistrationAddress }, false))

        <div class="lk-block-btn">
            <button type="submit" class="step-next btn" name="modal" value="bid-1">Сохранить и продолжить</button>
        </div>
    </div>
</form>

<script>
    function getDataDatabase(type, url) {
        $.ajax({ 
            type: type,
            url: url,       
            success: function (data) {
                $("#surname").val(data.surname);
                $("#name").val(data.name);
                $("#patronymic").val(data.patronymic);
                $("#snils").val(data.snils);
                $("#date_of_birth").val(data.dateOfBirth);
                $("#place_of_birth").val(data.placeOfBirth);
                $(".passport-text").html(data.passport);
                $("#passport").val(data.passport);
                $("#passport_series").val(data.passportSeries);
                $("#passport_number").val(data.passportNumber);
                $("#passport_date").val(data.passportDate);
                $("#passport_issued_by").val(data.passportIssuedBy);
                $("#phone").val(data.phoneNumber);
                $("#email").val(data.email);
                $("#address_reg").val(data.addressRegistration);
                $("#address_actual").val(data.addressActual);
            }
        });
    }

    $('.form-bid').on('submit',function(event){
        $('.preloader').show();
        event.preventDefault();
        var th = $(this);
    console.log(th.serialize());
        $.ajaxSetup({
            beforeSend: function(xhr) {
                var token = $('input[name="__RequestVerificationToken"]').val();
                xhr.setRequestHeader("RequestVerificationToken", token);
            }
        });
        $.ajax({
            url: "/Bid/Bid2",
            type:"POST",
            data:th.serialize(),
            success:function(data){
                $('.preloader').hide();
                console.log('Успешно');
                $('.lk-block-btn .btn').before('<div class="alert alert-success alert-profile"><i class="fas fa-check-circle"></i> Изменения сохранены</div>');
                setTimeout(() => {
                    $('.alert').slideUp('400', function(){
                        $(this).remove();
                    });
                }, 3000);
                window.location = "/Bid/Bid2";
            },
            error: function (err) {
                $('.preloader').hide();

                if (err.responseJSON.errors) {
                    $.each(err.responseJSON.errors, function(fieldName, messages) {
                        $.each(messages, function(index, message) {
                            $(`[name='container-${fieldName}']`).each(function() {
                                $(this).find('.form-group__error').remove();
                                $(this).find('.form-group__error form-group__error_home').remove();

                                $(this).append(`<div class="form-group__error">${message}</div>`);

                                $(this).removeClass('error').addClass('error');
                                if ($(this).find('.form-group__input').length>0) $(this).find('.form-group__input').removeClass('is-active').addClass('is-active')
                                else $(this).find(".select-block__title").removeClass('is-active').addClass('is-active')
                            });
                        });
                    });
                }
                
                $('.lk-block-btn .btn').before('<div class="alert alert-dunger alert-profile"><i class="fas fa-exclamation-circle"></i> Неверные данные</div>');
                setTimeout(() => {
                    $('.alert').slideUp('400', function(){
                        $(this).remove();
                    });
                }, 3000);
            }
        });
    });        
</script>